<!DOCTYPE html>
<html lang="ar">
<head<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">>
    <meta charset="UTF-8">
    <title>حاسبة المعدل التراكمي - Bootstrap</title>
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <!-- Bootstrap JS -->
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
    <!-- ملف JavaScript الخاص بنا (jQuery) -->
    <script src="script.js" defer></script>
</head>
<body>
    <h1>حاسبة المعدل التراكمي</h1>
    <form action="calculate.php" method="post" onsubmit="return validateForm()"<button type="button" id="clearAll" class="btn btn-warning mb-3">حذف الكل</button>>
        <div id="courses">
            <div class="course-row">
                <label>المقرر:</label>
                <input type="text" name="course[]" placeholder="مثال: رياضيات" required>
                <label>الساعات:</label>
                <input type="number" name="credits[]" placeholder="مثال: 3" min="1" required>
                <label>الدرجة:</label>
                <select name="grade[]">
                    <option value="4.0">A</option>
                    <option value="3.0">B</option>
                    <option value="2.0">C</option>
                    <option value="1.0">D</option>
                    <option value="0.0">F</option>
                </select>
            </div>
        </div>
        <button type="button" onclick="addCourse()">+ إضافة مقرر</button>
        <br><br>
        <input type="submit" value="احسب المعدل">
    </form>
</body>
</html>
